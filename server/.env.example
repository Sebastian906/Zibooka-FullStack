PORT=4000
MONGODB_URI=[base_de_datos_MONGO_aqui]
JWT_SECRET=[clave_secreta_JWT_aqui]
APP_ENV=production
ADMIN_EMAIL=[correo_admin_aqui]
ADMIN_PASS=[contraseña_admin_aqui]
ADMIN_PHONE=[telefono_admin_aqui]
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=[correo_de_gmail_del_que_se_va_a_enviar_los_correos]
EMAIL_PASS=[contraseña_de_gmail_proporcionada_por_google_apps_o_generada_en_configuración_de_cuenta]
FRONTEND_URL=[url_frontend_aqui]
CLDN_NAME=[nombre_de_ambiente_cloudinary_aqui]
CLDN_API_KEY=[api_key_cloudinary_aqui]
CLDN_SECRET_KEY=[secret_key_cloudinary_aqui]
STRIPE_SECRET_KEY=[clave_secreta_stripe_aqui]
STRIPE_WEBHOOK_SECRET=[clave_webhook_stripe_aqui]
ML_SERVICE_URL=[url_del_microservicio_ml_aqui]
RESERVATION_SCORE_ALPHA=0.4    # Peso de posición en cola
RESERVATION_SCORE_BETA=0.3     # Peso de puntualidad histórica
RESERVATION_SCORE_GAMMA=0.2    # Peso de tiempo de espera
RESERVATION_SCORE_DELTA=0.1    # Penalización por devoluciones tardías
LOAN_FEE_ESTIMATE=5.00  # Fee estimado por préstamo para optimización del carrito
THROTTLE_TTL=60000        # Ventana de tiempo en milisegundos (default: 60000 = 1 min)
THROTTLE_LIMIT=100        # Maximo de requests por ventana por IP (default: 100)
REDIS_HOST=localhost
REDIS_PORT=6379
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:4000/api/user/google/callback